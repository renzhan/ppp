# =============================================================================
# Unified Platform Environment Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to source control
# =============================================================================

# ── PostgreSQL Database ──
DATABASE_URL=postgresql://ppp_user:ppp_password@db:5432/ppp
POSTGRES_DB=ppp
POSTGRES_USER=ppp_user
POSTGRES_PASSWORD=ppp_password

# ── JWT Authentication ──
# Must be at least 32 characters for security
JWT_SECRET=your-jwt-secret-at-least-32-characters

# ── Service-to-Service Authentication ──
# API key for PPP Backend -> Presenton Backend communication
# Used in X-API-Key header for internal service calls
PRESENTON_API_KEY=your-presenton-api-key

# ── LLM Provider Configuration (PPP Backend) ──
# Provider: "openai" | "qwen"
LLM_PROVIDER=openai

# OpenAI-compatible API settings
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4o

# Qwen (DashScope) - used when LLM_PROVIDER=qwen
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_API_KEY=sk-your-qwen-api-key
QWEN_MODEL_CHAT=qwen3.6-plus
QWEN_MODEL_LITE=qwen3.6-flash

# ── Presenton Backend (AI/PPT Service) ──
# LLM provider for Presenton: openai | anthropic | google | azure | ollama
LLM=openai
OPENAI_API_KEY=your-openai-api-key

# Presenton Backend URL (for proxy routing)
# In Docker: http://presenton-backend:8000
# In development: http://localhost:5000
PRESENTON_BASE_URL=http://presenton-backend:8000

# ── External APIs ──
PAICHACHA_API_KEY=your-paichacha-api-key
PAICHACHA_BASE_URL=https://api.paichacha.com

# ── Security ──
# Encryption key for sensitive data at rest (at least 32 characters)
ENCRYPTION_KEY=your-encryption-key-at-least-32-chars
