# PostgreSQL (Supabase)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# LLM 提供商: "openai" (默认) | "qwen"
LLM_PROVIDER=openai

# ── OpenAI 兼容接口 ──
LLM_BASE_URL=https://aiop-gateway.item.com/proxy/openai/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-5.1

# ── Qwen (通义千问) DashScope ──
# LLM_PROVIDER=qwen 时使用以下配置
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_API_KEY=sk-your-qwen-api-key
QWEN_MODEL_CHAT=qwen3.6-plus
QWEN_MODEL_LITE=qwen3.6-flash
QWEN_MODEL_BASE=qwen3.6-27b
QWEN_EMBEDDING_MODEL=tongyi-embedding-vision-plus

# 派查查API
PAICHACHA_API_KEY=your-paichacha-api-key
PAICHACHA_BASE_URL=https://api.paichacha.com

# 蒲公英服务地址
PUGONGYING_NOTE_BASE_URL=http://47.114.122.60:6008
PUGONGYING_COMMENT_BASE_URL=http://47.114.122.60:6002
PUGONGYING_API_KEY=...

# 聚光的服务地址
JUGUANG_BASE_URL=http://47.114.122.60:6003
JUGUANG_API_KEY=...

# 灵犀服务的地址
LINGXI_BASE_URL=http://47.114.122.60:8000
LINGXI_API_KEY=...

