{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Full Stack: Web + Presenton API",
      "configurations": ["Web: open app", "Presenton API: dev"]
    }
  ],
  "configurations": [
    {
      "name": "Web: open app",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://127.0.0.1:3000",
      "webRoot": "${workspaceFolder}/web",
      "preLaunchTask": "Next.js: dev server"
    },
    {
      "name": "Web: open app (no debug)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://127.0.0.1:3000",
      "webRoot": "${workspaceFolder}/web",
      "preLaunchTask": "Next.js: dev server",
      "noDebug": true
    },
    {
      "name": "Presenton API: dev",
      "type": "python",
      "request": "launch",
      "cwd": "${workspaceFolder}/presenton-api",
      "program": "${workspaceFolder}/presenton-api/server.py",
      "python": "${workspaceFolder}/presenton/.venv/bin/python",
      "args": ["--port", "8000", "--reload", "true"],
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/presenton/.env",
      "env": {
        "APP_DATA_DIRECTORY": "${workspaceFolder}/presenton-api/app_data",
        "NEXT_PUBLIC_FAST_API": "http://127.0.0.1:8000",
        "USER_CONFIG_PATH": "${workspaceFolder}/presenton-api/app_data/userConfig.json"
      }
    },
    {
      "name": "Vitest: run all",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vitest", "run"],
      "console": "integratedTerminal"
    },
    {
      "name": "Vitest: debug current file",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "vitest",
        "run",
        "${relativeFile}",
        "--reporter=verbose"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "TypeScript: check",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsc", "--noEmit"],
      "console": "integratedTerminal"
    }
  ]
}
