{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@/ingestion/*": ["./src/ingestion/*"],
      "@/calculation/*": ["./src/calculation/*"],
      "@/report/*": ["./src/report/*"],
      "@/config/*": ["./src/config/*"],
      "@/shared/*": ["./src/shared/*"],
      "@/engines/*": ["./src/engines/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
